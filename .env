# Local development — copy this to .env and edit as needed
# DO NOT commit .env to git

FLASK_APP=run.py
FLASK_ENV=development

# Leave DATABASE_URL blank to use local SQLite (instance/shop.db)
# DATABASE_URL=postgresql://user:pass@localhost:5432/flaskshop

# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-change-me-must-be-32-chars-minimum!!
